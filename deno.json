{
  "imports": {
    "@oak/oak": "jsr:@oak/oak@^17.1.6",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "postgres/": "https://deno.land/x/postgres@v0.19.3/",
    "sentry": "npm:@sentry/deno@9.40.0",
    "cheerio/": "https://esm.sh/cheerio@1.0.0/"
  },
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-env main.ts",
    "dev": "deno run --allow-net --allow-read --allow-env --watch main.ts",
    "inspect": "deno run --allow-net --allow-env --allow-read --inspect main.ts"
  },
  "unstable": [
    "cron"
  ]
}